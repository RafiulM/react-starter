---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ValueProposition from '@/components/ValueProposition.astro';
import FeaturesSection from '@/components/FeaturesSection.astro';
import AuthCTA from '@/components/AuthCTA.astro';
import AIIntegrationHighlight from '@/components/AIIntegrationHighlight.astro';

const technologies = [
  "React 19", "TypeScript", "Astro", "TanStack Router", 
  "ShadCN UI", "Tailwind CSS", "Bun", "Hono", 
  "tRPC", "PostgreSQL", "Cloudflare", "Jotai"
];
---

<BaseLayout>
  <!-- Enhanced Hero Section -->
  <HeroSection />

  <!-- Value Proposition -->
  <ValueProposition />

  <!-- Enhanced Features Section -->
  <FeaturesSection />

  <!-- AI Integration Highlight -->
  <AIIntegrationHighlight />

  <!-- Tech Stack Section (Improved) -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-muted/30">
    <div class="container mx-auto max-w-7xl text-center">
      <h2 class="text-3xl font-bold tracking-tight mb-4 sm:text-4xl">
        Built with Modern Technologies
      </h2>
      <p class="text-muted-foreground text-lg mb-12 max-w-2xl mx-auto">
        Carefully selected technologies that work together seamlessly for optimal performance and developer experience
      </p>

      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
        {technologies.map((tech) => (
          <div class="group p-4 rounded-lg bg-background border hover:border-primary/20 transition-all duration-200 hover:shadow-sm">
            <span class="font-medium text-sm group-hover:text-primary transition-colors">{tech}</span>
          </div>
        ))}
      </div>

      <!-- Additional tech info -->
      <div class="mt-12 pt-8 border-t">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-muted-foreground">
          <div>
            <div class="font-semibold mb-2 text-foreground">Frontend</div>
            <p>React 19, TypeScript, Astro, TailwindCSS</p>
          </div>
          <div>
            <div class="font-semibold mb-2 text-foreground">Backend</div>
            <p>tRPC, PostgreSQL, Hono, Bun</p>
          </div>
          <div>
            <div class="font-semibold mb-2 text-foreground">Platform</div>
            <p>Cloudflare Workers, Edge Computing</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enhanced CTA Section -->
  <AuthCTA />
</BaseLayout>