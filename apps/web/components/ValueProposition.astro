---
import { Card, CardContent } from '@repo/ui';
---

<section class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="container mx-auto max-w-7xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight mb-4 sm:text-4xl lg:text-5xl">
        Why React Starter Kit?
      </h2>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
        Skip weeks of setup and configuration. Start building your product today with 
        enterprise-grade architecture and modern development practices.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Ship Faster -->
      <Card class="relative border-2 hover:border-primary/20 card-hover group" client:visible>
        <CardContent class="p-8 text-center">
          <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-green-500/10 to-green-600/10 group-hover:from-green-500/20 group-hover:to-green-600/20 transition-all duration-300 group-hover:scale-110">
            <svg class="h-8 w-8 text-green-600 group-hover:animate-float" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4 group-hover:text-green-600 transition-colors">Ship 10x Faster</h3>
          <p class="text-muted-foreground mb-6">
            Complete development environment with authentication, database, API, and deployment ready in minutes.
          </p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-green-500 group-hover:animate-pulse-glow"></div>
              <span>Pre-configured toolchain</span>
            </div>
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-green-500 group-hover:animate-pulse-glow delay-100"></div>
              <span>Production-ready templates</span>
            </div>
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-green-500 group-hover:animate-pulse-glow delay-200"></div>
              <span>One-command deployment</span>
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- Scale Globally -->
      <Card class="relative border-2 hover:border-primary/20 card-hover group" client:visible>
        <CardContent class="p-8 text-center">
          <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-blue-500/10 to-blue-600/10 group-hover:from-blue-500/20 group-hover:to-blue-600/20 transition-all duration-300 group-hover:scale-110">
            <svg class="h-8 w-8 text-blue-600 group-hover:animate-float delay-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4 group-hover:text-blue-600 transition-colors">Scale Globally</h3>
          <p class="text-muted-foreground mb-6">
            Built for edge computing with serverless architecture that scales automatically to handle millions of users.
          </p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-blue-500 group-hover:animate-pulse-glow"></div>
              <span>Edge-first deployment</span>
            </div>
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-blue-500 group-hover:animate-pulse-glow delay-100"></div>
              <span>Auto-scaling infrastructure</span>
            </div>
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-blue-500 group-hover:animate-pulse-glow delay-200"></div>
              <span>Global CDN distribution</span>
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- Developer Experience -->
      <Card class="relative border-2 hover:border-primary/20 card-hover group" client:visible>
        <CardContent class="p-8 text-center">
          <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-purple-500/10 to-purple-600/10 group-hover:from-purple-500/20 group-hover:to-purple-600/20 transition-all duration-300 group-hover:scale-110">
            <svg class="h-8 w-8 text-purple-600 group-hover:animate-float delay-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4 group-hover:text-purple-600 transition-colors">Love to Code</h3>
          <p class="text-muted-foreground mb-6">
            Modern developer experience with TypeScript, hot reload, testing, and all the tools you need to stay productive.
          </p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-purple-500 group-hover:animate-pulse-glow"></div>
              <span>Full TypeScript support</span>
            </div>
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-purple-500 group-hover:animate-pulse-glow delay-100"></div>
              <span>Hot module replacement</span>
            </div>
            <div class="flex items-center justify-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-purple-500 group-hover:animate-pulse-glow delay-200"></div>
              <span>Built-in testing suite</span>
            </div>
          </div>
        </CardContent>
      </Card>
    </div>

    <!-- Stats -->
    <div class="mt-20 border-t pt-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-primary mb-2">99+</div>
          <div class="text-sm text-muted-foreground">Lighthouse Score</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary mb-2">50ms</div>
          <div class="text-sm text-muted-foreground">Cold Start Time</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary mb-2">10k+</div>
          <div class="text-sm text-muted-foreground">Developers Using</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary mb-2">100%</div>
          <div class="text-sm text-muted-foreground">Type Safety</div>
        </div>
      </div>
    </div>
  </div>
</section>