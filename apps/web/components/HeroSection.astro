---
import { Button } from '@repo/ui';
---

<section class="relative overflow-hidden bg-gradient-to-br from-background via-muted/20 to-secondary/30 px-4 py-20 sm:px-6 lg:px-8 xl:py-32">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-grid-white/5 bg-[size:20px_20px] [mask-image:radial-gradient(ellipse_at_center,transparent_20%,black)]" aria-hidden="true"></div>
  <div class="absolute -top-40 -right-32 w-72 h-72 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-full blur-3xl" aria-hidden="true"></div>
  <div class="absolute -bottom-40 -left-32 w-72 h-72 bg-gradient-to-br from-accent/20 to-primary/20 rounded-full blur-3xl" aria-hidden="true"></div>
  
  <div class="container relative mx-auto max-w-7xl">
    <div class="text-center">
      <!-- Main Headline -->
      <div class="mb-8">
        <div class="mb-4 inline-flex items-center rounded-full border px-4 py-2 text-sm text-muted-foreground animate-fade-in delay-200">
          <span class="mr-2 h-2 w-2 rounded-full bg-green-500 animate-pulse-glow"></span>
          Now available - Version 2.0
        </div>
        <h1 class="mb-6 text-4xl font-bold tracking-tight sm:text-6xl lg:text-7xl animate-fade-in-up delay-300">
          <span class="bg-gradient-to-r from-foreground via-primary to-foreground bg-clip-text text-transparent">
            React Starter Kit
          </span>
        </h1>
        <p class="mx-auto max-w-3xl text-xl text-muted-foreground sm:text-2xl animate-fade-in-up delay-500">
          The modern full-stack web application template that developers love. 
          Build faster, deploy anywhere, scale effortlessly.
        </p>
      </div>

      <!-- Value Props -->
      <div class="mb-10 grid gap-4 sm:grid-cols-3 animate-fade-in delay-700">
        <div class="flex items-center justify-center gap-2 text-sm text-muted-foreground">
          <div class="h-2 w-2 rounded-full bg-green-500 animate-pulse-glow"></div>
          <span>99+ Lighthouse Score</span>
        </div>
        <div class="flex items-center justify-center gap-2 text-sm text-muted-foreground">
          <div class="h-2 w-2 rounded-full bg-blue-500 animate-pulse-glow delay-100"></div>
          <span>Edge-First Architecture</span>
        </div>
        <div class="flex items-center justify-center gap-2 text-sm text-muted-foreground">
          <div class="h-2 w-2 rounded-full bg-purple-500 animate-pulse-glow delay-200"></div>
          <span>Type-Safe Everything</span>
        </div>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row animate-fade-in-up delay-700">
        <Button size="lg" class="h-12 px-8 text-lg btn-glow hover:scale-105 transition-transform duration-200" asChild client:visible>
          <a href="#get-started">
            Get Started Free
            <svg class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </Button>
        <Button variant="outline" size="lg" class="h-12 px-8 text-lg hover:scale-105 transition-transform duration-200" asChild client:visible>
          <a href="#demo">
            View Live Demo
            <svg class="ml-2 h-5 w-5 transition-transform group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h.01M19 10a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </a>
        </Button>
      </div>

      <!-- Trust Indicators -->
      <div class="mt-16 animate-fade-in delay-700">
        <p class="mb-8 text-sm text-muted-foreground">Trusted by developers at</p>
        <div class="flex items-center justify-center gap-8 opacity-60">
          <div class="text-sm font-semibold hover:opacity-100 transition-opacity duration-200 cursor-default">GitHub</div>
          <div class="text-sm font-semibold hover:opacity-100 transition-opacity duration-200 cursor-default">Vercel</div>
          <div class="text-sm font-semibold hover:opacity-100 transition-opacity duration-200 cursor-default">Cloudflare</div>
          <div class="text-sm font-semibold hover:opacity-100 transition-opacity duration-200 cursor-default">Netlify</div>
        </div>
      </div>
    </div>
  </div>
</section>