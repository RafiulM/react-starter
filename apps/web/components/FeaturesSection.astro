---
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@repo/ui';

const features = [
  {
    icon: "⚡",
    title: "Lightning Performance",
    description: "SSR at CDN edge locations with ~100ms response times",
    content: "Optimized for Cloudflare Workers with Bun runtime for maximum performance. Your users get instant page loads worldwide.",
    color: "from-yellow-500 to-orange-500"
  },
  {
    icon: "🎨",
    title: "Beautiful UI Components",
    description: "Production-ready components with ShadCN UI and Tailwind",
    content: "50+ pre-built components following modern design principles, accessibility standards (WCAG 2.1 AA), and dark mode support.",
    color: "from-pink-500 to-violet-500"
  },
  {
    icon: "🚀",
    title: "Incredible DX",
    description: "TypeScript, hot reload, and excellent tooling",
    content: "Full TypeScript support with Vite, TanStack Router, ESLint, Prettier, and modern development tools for maximum productivity.",
    color: "from-blue-500 to-cyan-500"
  },
  {
    icon: "🔐",
    title: "Full-Stack Auth",
    description: "Complete authentication system with PostgreSQL",
    content: "User management, sessions, permissions, OAuth providers, and secure password handling. Ready for production.",
    color: "from-green-500 to-emerald-500"
  },
  {
    icon: "📊",
    title: "tRPC API",
    description: "Type-safe APIs with automatic validation",
    content: "End-to-end type safety from database to frontend. Auto-generated client with React Query integration for caching.",
    color: "from-indigo-500 to-purple-500"
  },
  {
    icon: "☁️",
    title: "Edge-Ready Deploy",
    description: "Deploy to Cloudflare Workers worldwide",
    content: "Built for serverless deployment with automatic scaling, global distribution, and zero cold start times.",
    color: "from-teal-500 to-green-500"
  }
];
---

<section class="py-20 px-4 sm:px-6 lg:px-8 bg-muted/20">
  <div class="container mx-auto max-w-7xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight mb-4 sm:text-4xl lg:text-5xl">
        Everything you need to build modern web apps
      </h2>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
        React Starter Kit provides a solid foundation with best practices, 
        modern tooling, and optimized performance out of the box.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature, index) => (
        <Card 
          class={`group relative overflow-hidden border-2 hover:border-primary/20 transition-all duration-300 hover:shadow-lg`}
          client:visible
        >
          <!-- Background gradient -->
          <div class={`absolute inset-0 bg-gradient-to-br ${feature.color} opacity-0 group-hover:opacity-5 transition-opacity duration-300`}></div>
          
          <CardHeader>
            <div class="flex items-center gap-3 mb-2">
              <div class={`flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br ${feature.color} text-white text-xl shadow-lg`}>
                {feature.icon}
              </div>
              <div>
                <CardTitle class="text-lg">{feature.title}</CardTitle>
                <CardDescription class="mt-1">{feature.description}</CardDescription>
              </div>
            </div>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground leading-relaxed">{feature.content}</p>
            
            <!-- Feature badge -->
            <div class="mt-4">
              <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
                {index < 2 ? "Popular" : "Essential"}
              </span>
            </div>
          </CardContent>
        </Card>
      ))}
    </div>

    <!-- Feature comparison -->
    <div class="mt-20">
      <div class="text-center mb-12">
        <h3 class="text-2xl font-bold mb-4">How we compare</h3>
        <p class="text-muted-foreground">See why developers choose React Starter Kit over alternatives</p>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full border-collapse border border-border rounded-lg">
          <thead>
            <tr class="bg-muted/50">
              <th class="border border-border p-4 text-left font-semibold">Feature</th>
              <th class="border border-border p-4 text-center font-semibold text-primary">React Starter Kit</th>
              <th class="border border-border p-4 text-center font-semibold text-muted-foreground">Create React App</th>
              <th class="border border-border p-4 text-center font-semibold text-muted-foreground">Next.js Starter</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border border-border p-4 font-medium">Edge Deployment</td>
              <td class="border border-border p-4 text-center">
                <span class="text-green-600">✓</span>
              </td>
              <td class="border border-border p-4 text-center text-muted-foreground">✗</td>
              <td class="border border-border p-4 text-center text-muted-foreground">Partial</td>
            </tr>
            <tr class="bg-muted/20">
              <td class="border border-border p-4 font-medium">Full-Stack Auth</td>
              <td class="border border-border p-4 text-center">
                <span class="text-green-600">✓</span>
              </td>
              <td class="border border-border p-4 text-center text-muted-foreground">✗</td>
              <td class="border border-border p-4 text-center text-muted-foreground">✗</td>
            </tr>
            <tr>
              <td class="border border-border p-4 font-medium">Type-Safe APIs</td>
              <td class="border border-border p-4 text-center">
                <span class="text-green-600">✓</span>
              </td>
              <td class="border border-border p-4 text-center text-muted-foreground">✗</td>
              <td class="border border-border p-4 text-center text-muted-foreground">Partial</td>
            </tr>
            <tr class="bg-muted/20">
              <td class="border border-border p-4 font-medium">Database Setup</td>
              <td class="border border-border p-4 text-center">
                <span class="text-green-600">✓</span>
              </td>
              <td class="border border-border p-4 text-center text-muted-foreground">✗</td>
              <td class="border border-border p-4 text-center text-muted-foreground">✗</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>